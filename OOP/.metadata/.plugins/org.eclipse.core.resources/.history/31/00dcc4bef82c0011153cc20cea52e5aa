package testProject3;

public class Argument2_1 {

	public static void main(String[] args) {
		System.out.println("card width: " +  Card.width);     // 클래스 변수는 인스턴스를 생성하지 않아도 사용 가능
		System.out.println("card height: " +  Card.height);
		
		Card c1 = new Card();  // 인스턴스를 생성함으로서 인스턴스 변수들 생성
		c1.kind = "Heart";     // 참조변수.인스턴스변수명 으로 접근
		c1.number = 7;
		
		Card c2 = new Card();
		c2.kind = "Spade";
		c2.number = 4;
		
		System.out.println("c1은" + c1.number + c1.kind + "이며 크기는 크기는 (" + c1.width + c1.height + ")");   // 클래스 변수 접근은 참조변수명.클래스변수명 보다 클래스이름.클래스변수명 로 접근 권장
		System.out.println("c2은" + c2.number + c2.kind + "이며 크기는 크기는 (" + c2.width + c2.height + ")");
		System.out.println("c1의 width 와 height를 각각 50, 80 으로 변경");
		
		c1.width = 50;  // c1을 이용해 클래스변수인 width 와 height 변경
		c1.height = 80;
		
		System.out.println("c1은" + c1.number + c1.kind + "이며 크기는 크기는 (" + c1.width + ", " + c1.height + ")");   // c1을 이용하여 width 와 height 를 변경하였지만 클래스변수는 모든 인스턴스들이 공유하기 떄문에
		System.out.println("c2은" + c2.number + c2.kind + "이며 크기는 크기는 (" + c2.width + ", " + c2.height + ")");   // c2를 이용해 width 와 height 에 접근해도 바뀐값이 출력됨
		
//		for(int i=1; i<10; i++) {     for, if 와 같은 매서드 안에서 생성된 지역변수는 메서드 종료시 소멸
//			int temp = i;             << 변수생성
//		}                             << for 블럭이 끝났으므로 변수 소멸
//		System.out.println(temp);     << for 안에서 생성된 지역변를 호출했으므로 에러
	}

}

class Card {
	String kind;
	int number;
	static int width = 100;
	static int height = 250;
}
