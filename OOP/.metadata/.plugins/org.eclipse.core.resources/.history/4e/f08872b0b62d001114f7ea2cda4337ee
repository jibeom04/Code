package testProject3;

public class Assignment3_1 {

	public static void main(String[] args) {
		System.out.println(MyMath.add(200L, 100L)); // 클래스메서드 호출
		MyMath mm = new MyMath();
		mm.a = 200L;
		mm.b = 100L;
		System.out.println(mm.add());  // 인스턴스메서드 호출
	}
}

class MyMath {
	long a, b;
	long add() {         // 인스턴스 메서드
		return a + b;
	}
	static long add(long a, long b) {
		return a + b;
	}
}

class TestClass {
	void instanceMethod() {}        // 인스턴스메서드
	static void staticMethod() {}   // 스태팃메서드
	
	void instanceMethod2() {        // 인스턴스메서드 안에서
		instanceMethod();           // 인스턴스메서드 호출
		staticMethod();             // 스태틱메서드 호출 가능
	}
	
	static void staticMethod2() {
		staticMethod();             // 스태틱메서드는 인스턴스메서드, 스태틱메서드에서 호출 가능하지만
//		instanceMethod();              스태틱메서드 에서는 인스턴트 메서드에 접근할 수 없으므로 에러
		}
}                                   // 변수도 메소드와 동일
