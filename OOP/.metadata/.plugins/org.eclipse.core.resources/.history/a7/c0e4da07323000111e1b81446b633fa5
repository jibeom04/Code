package testProject3;

public class Assignment3_1 {

	public static void main(String[] args) {
		System.out.println(MyMath.add(200L, 100L)); // 클래스메서드 호출
		MyMath mm = new MyMath();
		mm.a = 200L;
		mm.b = 100L;
		System.out.println(mm.add());  // 인스턴스메서드 호출
	}
}

class MyMath {
	long a, b;  // 인스턴스 변수 생성
	
	// 인스턴스 메서드 생성. 인스턴스 변수 a, b만 이용하여 작업하므로 매개변수 불필요
	long add() { return a + b; }
	long subtract() { return a - b; }
	long multiply() { return a - b;}
	long divide() { return a / b; }
	
	// 클래스 메서드 생성. 인스턴스 변수와 관계없이 매개변수 만으로 작업 가능
	static long add(long a, long b) { return a + b; }
	static long subtract(long a, long b) { return a - b; }
	static long multiply(long a, long b) { return a - b;}
	static long divide(long a, long b) { return a / b; }
	
}